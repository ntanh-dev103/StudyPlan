<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sp_background"
    android:orientation="vertical">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/bg_toolbar_blue"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="Menu"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:tint="@color/white" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.02"
            android:text="StudyPlan"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/btn_notification"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Thông báo"
            android:padding="2dp"
            android:src="@android:drawable/ic_popup_reminder"
            android:tint="@color/white" />

        <!-- Avatar: chữ cái đầu tên user -->
        <TextView
            android:id="@+id/tv_avatar_home"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_avatar_circle"
            android:gravity="center"
            android:text="?"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- ── Greeting Card ────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:background="@drawable/bg_greeting_gradient"
                android:elevation="6dp"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- Ngày hiện tại — lấy bằng Calendar trong Java -->
                    <TextView
                        android:id="@+id/tv_today_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="..."
                        android:textColor="#D0D4FF"
                        android:textSize="11sp"
                        android:letterSpacing="0.05" />

                    <!-- Lời chào + tên user -->
                    <TextView
                        android:id="@+id/tv_greeting_hello"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="4dp"
                        android:text="Xin chào! 👋"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <!-- Stats Chips row 1 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp">

                        <!-- Chip Hoàn thành -->
                        <TextView
                            android:id="@+id/tv_chip_done"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_chip_green"
                            android:paddingStart="10dp"
                            android:paddingTop="4dp"
                            android:paddingEnd="10dp"
                            android:paddingBottom="4dp"
                            android:text="● Hoàn thành: 0"
                            android:textColor="@color/chip_green_text"
                            android:textSize="10sp" />

                        <!-- Chip Đang làm -->
                        <TextView
                            android:id="@+id/tv_chip_in_progress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:background="@drawable/bg_chip_blue"
                            android:paddingStart="10dp"
                            android:paddingTop="4dp"
                            android:paddingEnd="10dp"
                            android:paddingBottom="4dp"
                            android:text="● Đang làm: 0"
                            android:textColor="@color/chip_blue_text"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <!-- Chip Chưa làm -->
                    <TextView
                        android:id="@+id/tv_chip_not_started"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="● Chưa làm: 0"
                        android:textColor="#D0D4FF"
                        android:textSize="10sp" />
                </LinearLayout>

                <!-- Task ratio badge: done/total -->
                <FrameLayout
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:orientation="vertical">

                        <!-- tv_stat_total: tổng done/total -->
                        <TextView
                            android:id="@+id/tv_stat_total"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0/0"
                            android:textColor="@color/white"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="tasks"
                            android:textColor="#D0D4FF"
                            android:textSize="10sp" />
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>

            <!-- ── Hidden stats TextViews (dùng trong HomeFragment) ── -->
            <!-- tv_stat_done, tv_stat_in_progress, tv_stat_not_started -->
            <!-- Ẩn khỏi UI, chỉ dùng để Java lấy giá trị -->
            <TextView
                android:id="@+id/tv_stat_done"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="0"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_stat_in_progress"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="0"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_stat_not_started"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="0"
                android:visibility="gone" />

            <!-- ── Quick Action Grid 2×2 ──────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="16dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:id="@+id/quick_action_subject"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_card_elevated"
                        android:elevation="3dp"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:contentDescription="Môn học"
                            android:src="@android:drawable/ic_menu_agenda"
                            android:tint="@color/module_subject" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Môn học"
                            android:textColor="@color/sp_text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/quick_action_schedule"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_card_elevated"
                        android:elevation="3dp"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:contentDescription="Lịch học"
                            android:src="@android:drawable/ic_menu_my_calendar"
                            android:tint="@color/module_schedule" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Lịch học"
                            android:textColor="@color/sp_text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">

                    <LinearLayout
                        android:id="@+id/quick_action_assignment"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_card_elevated"
                        android:elevation="3dp"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:contentDescription="Bài tập"
                            android:src="@android:drawable/ic_menu_edit"
                            android:tint="@color/module_assignment" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Bài tập"
                            android:textColor="@color/sp_text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/quick_action_account"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_card_elevated"
                        android:elevation="3dp"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:contentDescription="Tài khoản"
                            android:src="@android:drawable/ic_menu_manage"
                            android:tint="@color/module_account" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Tài khoản"
                            android:textColor="@color/sp_text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ── Section: Lịch học hôm nay ─────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📅 Lịch học hôm nay"
                    android:textColor="@color/sp_text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_view_all_schedule"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="4dp"
                    android:text="@string/view_all"
                    android:textColor="@color/sp_primary"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Container render động từ ScheduleDAO.getTodaySchedule() -->
            <LinearLayout
                android:id="@+id/ll_today_schedules"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="16dp"
                android:orientation="vertical" />

            <!-- Empty state lịch học: "Hôm nay chưa có lịch học" -->
            <TextView
                android:id="@+id/tv_empty_schedule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_card_elevated"
                android:gravity="center"
                android:padding="20dp"
                android:text="🎉 Hôm nay chưa có lịch học"
                android:textColor="@color/sp_text_secondary"
                android:textSize="14sp"
                android:visibility="gone" />

            <!-- ── Section: Deadline sắp đến ──────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⚠ Deadline sắp đến"
                    android:textColor="@color/sp_text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_view_all_deadline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="4dp"
                    android:text="@string/view_all"
                    android:textColor="@color/status_late"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Container render động từ AssignmentDAO.getUpcomingDeadlines() -->
            <LinearLayout
                android:id="@+id/ll_upcoming_deadlines"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="16dp"
                android:orientation="vertical" />

            <!-- Empty state deadline: "Không có deadline sắp tới" -->
            <TextView
                android:id="@+id/tv_empty_deadline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_card_elevated"
                android:gravity="center"
                android:padding="20dp"
                android:text="✅ Không có deadline sắp tới"
                android:textColor="@color/sp_text_secondary"
                android:textSize="14sp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
