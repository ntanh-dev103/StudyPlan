<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Google Logo + Mô tả -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_card_elevated"
            android:elevation="4dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="G"
                android:textColor="#4285F4"
                android:textSize="28sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="Đăng nhập bằng Google"
            android:textColor="@color/sp_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="Nhập thông tin tài khoản Google của bạn"
            android:textColor="@color/sp_text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Họ và tên -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Họ và tên *"
        android:textColor="@color/sp_text_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/et_google_name"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_input_field"
        android:hint="Tên hiển thị Google của bạn"
        android:inputType="textPersonName"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:textColor="@color/sp_text_primary"
        android:textColorHint="@color/sp_text_secondary"
        android:textSize="14sp" />

    <!-- Email Google -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="Email Google *"
        android:textColor="@color/sp_text_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/et_google_email"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_input_field"
        android:hint="example@gmail.com"
        android:inputType="textEmailAddress"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:textColor="@color/sp_text_primary"
        android:textColorHint="@color/sp_text_secondary"
        android:textSize="14sp" />

    <!-- Error TextView -->
    <TextView
        android:id="@+id/tv_google_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/status_late"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- Ghi chú -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_info_card_blue"
        android:gravity="center"
        android:padding="10dp"
        android:text="💡 Khi Firebase được liên kết, đăng nhập Google sẽ tự động xử lý mà không cần nhập thủ công."
        android:textColor="@color/blue_dark"
        android:textSize="11sp" />

</LinearLayout>
