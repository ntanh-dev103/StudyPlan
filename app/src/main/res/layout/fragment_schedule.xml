<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="60dp"
            android:background="@drawable/bg_gradient_purple" android:gravity="center_vertical"
            android:paddingStart="16dp" android:paddingEnd="16dp">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_revert" android:tint="@color/white" android:contentDescription="Back" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:gravity="center" android:text="@string/nav_schedule" android:textColor="@color/white"
                android:textSize="22sp" android:textStyle="bold" />
            <ImageView android:id="@+id/btn_add_schedule"
                android:layout_width="28dp" android:layout_height="28dp" android:layout_marginEnd="12dp"
                android:padding="2dp"
                android:src="@android:drawable/ic_menu_add" android:tint="@color/white"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Add" />
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_manage" android:tint="@color/white" android:contentDescription="Settings" />
        </LinearLayout>

        <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
            android:scrollbars="none">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <!-- Month navigation -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="center">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@android:drawable/ic_media_previous" android:tint="@color/text_primary" android:contentDescription="Prev" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                        android:text="@string/month_title" android:textColor="@color/text_primary"
                        android:textSize="18sp" android:textStyle="bold" />
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:src="@android:drawable/ic_media_next" android:tint="@color/text_primary" android:contentDescription="Next" />
                </LinearLayout>

                <!-- Semester chips -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="12dp" android:gravity="center">
                    <TextView android:id="@+id/chip_sem_1"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:background="@drawable/bg_tab_purple_selected" android:paddingStart="16dp"
                        android:paddingTop="6dp" android:paddingEnd="16dp" android:paddingBottom="6dp"
                        android:text="T5-2026" android:textColor="@color/white" android:textSize="12sp" />
                    <TextView android:id="@+id/chip_sem_2"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="8dp" android:background="@drawable/bg_tab_unselected"
                        android:paddingStart="16dp" android:paddingTop="6dp" android:paddingEnd="16dp" android:paddingBottom="6dp"
                        android:text="T6-2026" android:textColor="@color/text_secondary" android:textSize="12sp" />
                    <TextView android:id="@+id/chip_sem_3"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="8dp" android:background="@drawable/bg_tab_unselected"
                        android:paddingStart="16dp" android:paddingTop="6dp" android:paddingEnd="16dp" android:paddingBottom="6dp"
                        android:text="T7-2026" android:textColor="@color/text_secondary" android:textSize="12sp" />
                </LinearLayout>

                <!-- Calendar Grid -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="16dp" android:background="@drawable/bg_card_elevated"
                    android:elevation="3dp" android:orientation="vertical" android:padding="12dp">

                    <!-- Day headers -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:gravity="center" android:text="T2" android:textColor="@color/text_secondary" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:gravity="center" android:text="T3" android:textColor="@color/text_secondary" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:gravity="center" android:text="T4" android:textColor="@color/text_secondary" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:gravity="center" android:text="T5" android:textColor="@color/text_secondary" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:gravity="center" android:text="T6" android:textColor="@color/text_secondary" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:gravity="center" android:text="T7" android:textColor="@color/text_secondary" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:gravity="center" android:text="CN" android:textColor="@color/status_late" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Week 1 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="40dp" android:layout_marginTop="4dp">
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                            android:gravity="center" android:textColor="@color/calendar_inactive" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                            android:gravity="center" android:textColor="@color/calendar_inactive" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                            android:gravity="center" android:text="29" android:textColor="@color/calendar_inactive" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                            android:gravity="center" android:text="30" android:textColor="@color/calendar_inactive" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                            android:gravity="center" android:text="1" android:textColor="@color/text_primary" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                            android:gravity="center" android:text="2" android:textColor="@color/text_primary" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                            android:gravity="center" android:text="3" android:textColor="@color/status_late" android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Week 2 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="40dp">
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="4" android:textColor="@color/text_primary" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="5" android:textColor="@color/text_primary" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="6" android:textColor="@color/text_primary" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="7" android:textColor="@color/text_primary" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="8" android:textColor="@color/text_primary" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="9" android:textColor="@color/text_primary" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="10" android:textColor="@color/status_late" android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Week 3 (today=14) -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="40dp">
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="11" android:textColor="@color/text_primary" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="12" android:textColor="@color/text_primary" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="13" android:textColor="@color/text_primary" android:textSize="14sp" />
                        <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                            <TextView android:layout_width="32dp" android:layout_height="32dp" android:layout_gravity="center"
                                android:background="@drawable/bg_calendar_today" android:gravity="center"
                                android:text="14" android:textColor="@color/white" android:textSize="14sp" android:textStyle="bold" />
                        </FrameLayout>
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="15" android:textColor="@color/text_primary" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="16" android:textColor="@color/text_primary" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="17" android:textColor="@color/status_late" android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Week 4 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="40dp">
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="18" android:textColor="@color/text_primary" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="19" android:textColor="@color/text_primary" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="20" android:textColor="@color/text_primary" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="21" android:textColor="@color/text_primary" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="22" android:textColor="@color/text_primary" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="23" android:textColor="@color/text_primary" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="24" android:textColor="@color/status_late" android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Week 5 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="40dp">
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="25" android:textColor="@color/text_primary" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="26" android:textColor="@color/text_primary" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="27" android:textColor="@color/text_primary" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="28" android:textColor="@color/text_primary" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="29" android:textColor="@color/text_primary" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="30" android:textColor="@color/text_primary" android:textSize="14sp" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:text="31" android:textColor="@color/status_late" android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Search bar for schedule -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:layout_marginTop="16dp" android:background="@drawable/bg_search_box_purple"
                    android:addStatesFromChildren="true"
                    android:gravity="center_vertical" android:paddingStart="12dp" android:paddingEnd="12dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_search" android:tint="@color/text_hint"
                        android:contentDescription="Search schedule" />
                    <EditText android:id="@+id/et_search_schedule"
                        android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                        android:layout_marginStart="8dp" android:background="@null"
                        android:hint="Tìm môn học, phòng học..." android:textColorHint="@color/text_hint"
                        android:textColor="@color/text_primary" android:textSize="14sp"
                        android:inputType="text" android:maxLines="1" />
                </LinearLayout>

                <!-- Day filter chips -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:scrollbars="none">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:id="@+id/chip_day_all"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:background="@drawable/bg_chip_orange_selected" android:paddingStart="14dp"
                            android:paddingTop="7dp" android:paddingEnd="14dp" android:paddingBottom="7dp"
                            android:text="Tất cả" android:textColor="@color/white" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:id="@+id/chip_day_today"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginStart="8dp" android:background="@drawable/bg_chip_unselected"
                            android:paddingStart="14dp" android:paddingTop="7dp" android:paddingEnd="14dp" android:paddingBottom="7dp"
                            android:text="Hôm nay" android:textColor="@color/text_secondary" android:textSize="13sp" />
                        <TextView android:id="@+id/chip_day_week"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginStart="8dp" android:background="@drawable/bg_chip_unselected"
                            android:paddingStart="14dp" android:paddingTop="7dp" android:paddingEnd="14dp" android:paddingBottom="7dp"
                            android:text="Tuần" android:textColor="@color/text_secondary" android:textSize="13sp" />
                        <TextView android:id="@+id/chip_day_t2"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginStart="8dp" android:background="@drawable/bg_chip_unselected"
                            android:paddingStart="14dp" android:paddingTop="7dp" android:paddingEnd="14dp" android:paddingBottom="7dp"
                            android:text="T2" android:textColor="@color/text_secondary" android:textSize="13sp" />
                        <TextView android:id="@+id/chip_day_t3"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginStart="8dp" android:background="@drawable/bg_chip_unselected"
                            android:paddingStart="14dp" android:paddingTop="7dp" android:paddingEnd="14dp" android:paddingBottom="7dp"
                            android:text="T3" android:textColor="@color/text_secondary" android:textSize="13sp" />
                        <TextView android:id="@+id/chip_day_t4"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginStart="8dp" android:background="@drawable/bg_chip_unselected"
                            android:paddingStart="14dp" android:paddingTop="7dp" android:paddingEnd="14dp" android:paddingBottom="7dp"
                            android:text="T4" android:textColor="@color/text_secondary" android:textSize="13sp" />
                        <TextView android:id="@+id/chip_day_t5"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginStart="8dp" android:background="@drawable/bg_chip_unselected"
                            android:paddingStart="14dp" android:paddingTop="7dp" android:paddingEnd="14dp" android:paddingBottom="7dp"
                            android:text="T5" android:textColor="@color/text_secondary" android:textSize="13sp" />
                        <TextView android:id="@+id/chip_day_t6"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginStart="8dp" android:background="@drawable/bg_chip_unselected"
                            android:paddingStart="14dp" android:paddingTop="7dp" android:paddingEnd="14dp" android:paddingBottom="7dp"
                            android:text="T6" android:textColor="@color/text_secondary" android:textSize="13sp" />
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Auto schedule card -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="16dp" android:background="@drawable/bg_card_elevated"
                    android:elevation="3dp" android:padding="16dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/auto_schedule_title" android:textColor="@color/text_primary"
                            android:textSize="15sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="4dp" android:text="@string/auto_schedule_desc"
                            android:textColor="@color/text_secondary" android:textSize="12sp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/btn_auto_schedule"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:background="@drawable/bg_button_green" android:paddingStart="14dp"
                            android:paddingTop="8dp" android:paddingEnd="14dp" android:paddingBottom="8dp"
                            android:text="@string/btn_auto_schedule" android:textColor="@color/white" android:textSize="12sp" />
                        <TextView android:id="@+id/btn_manual_schedule"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="8dp" android:background="@drawable/bg_button_outline"
                            android:paddingStart="14dp" android:paddingTop="6dp" android:paddingEnd="14dp" android:paddingBottom="6dp"
                            android:text="@string/btn_manual_schedule" android:textColor="@color/text_secondary" android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Schedule count + title -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="20dp" android:gravity="center_vertical">
                    <TextView android:id="@+id/tv_schedule_title"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="@string/schedule_day_title" android:textColor="@color/text_primary"
                        android:textSize="16sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tv_schedule_count"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge_blue" android:paddingStart="10dp"
                        android:paddingTop="3dp" android:paddingEnd="10dp" android:paddingBottom="3dp"
                        android:text="0" android:textColor="@color/chip_blue_text" android:textSize="12sp" android:textStyle="bold" />
                </LinearLayout>

                <!-- RecyclerView for timeline -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_timeline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false"
                    android:paddingBottom="80dp"
                    android:nestedScrollingEnabled="false" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_schedule"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        android:src="@android:drawable/ic_input_add"
        android:tint="@color/white"
        android:backgroundTint="@color/purple_primary"
        android:contentDescription="Add schedule" />

</RelativeLayout>
